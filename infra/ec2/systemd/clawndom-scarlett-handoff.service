[Unit]
Description=Trigger Scarlett's daily platform digest via /api/tasks
After=clawndom.service
Wants=clawndom.service

[Service]
Type=oneshot
User=clawndom
Group=clawndom
EnvironmentFile=/etc/clawndom/clawndom.env
ExecStart=/opt/clawndom/scripts/scarlett-daily-handoff.sh
StandardOutput=append:/var/log/clawndom/scarlett-handoff.log
StandardError=append:/var/log/clawndom/scarlett-handoff.log
