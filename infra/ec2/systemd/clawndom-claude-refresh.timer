[Unit]
Description=Periodic Claude OAuth token refresh
Requires=clawndom-claude-refresh.service

[Timer]
# First refresh shortly after boot, then every 2 hours.
# Token lifetime is ~8h; the script itself is a no-op when the current
# token still has >2h of life, so the actual network call lands a few
# times per day.
OnBootSec=2min
OnUnitActiveSec=2h
AccuracySec=30s
Persistent=true

[Install]
WantedBy=timers.target
